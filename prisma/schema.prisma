generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model LlmUsageLog {
  id           Int      @id @default(autoincrement())
  provider     String
  model        String
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  totalTokens  Int      @map("total_tokens")
  feature      String
  requestId    String?  @map("request_id")
  metadata     String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("llm_usage_logs")
}

model TaskDecision {
  id            Int      @id @default(autoincrement())
  tasksInput    String   @map("tasks_input")
  energyLevel   Int      @map("energy_level")
  availableTime Int      @map("available_time")
  provider      String
  model         String
  result        String
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("task_decisions")
}

model Document {
  id        Int             @id @default(autoincrement())
  filename  String
  mimeType  String          @map("mime_type")
  sizeBytes Int             @map("size_bytes")
  createdAt DateTime        @default(now()) @map("created_at")
  chunks    DocumentChunk[]

  @@map("documents")
}

model DocumentChunk {
  id         Int      @id @default(autoincrement())
  documentId Int      @map("document_id")
  content    String
  chunkIndex Int      @map("chunk_index")
  embedding  Bytes
  createdAt  DateTime @default(now()) @map("created_at")
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_chunks")
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("push_subscriptions")
}

model NotificationSetting {
  id               Int      @id @default(autoincrement())
  reminderEnabled  Boolean  @default(false) @map("reminder_enabled")
  reminderTime     String   @default("09:00") @map("reminder_time")
  budgetAlert      Boolean  @default(true) @map("budget_alert")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}
