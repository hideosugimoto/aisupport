generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model LlmUsageLog {
  id           Int      @id @default(autoincrement())
  userId       String   @default("legacy") @map("user_id")
  provider     String
  model        String
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  totalTokens  Int      @map("total_tokens")
  feature      String
  requestId    String?  @map("request_id")
  metadata     String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("llm_usage_logs")
}

model TaskDecision {
  id            Int      @id @default(autoincrement())
  userId        String   @default("legacy") @map("user_id")
  tasksInput    String   @map("tasks_input")
  energyLevel   Int      @map("energy_level")
  availableTime Int      @map("available_time")
  provider      String
  model         String
  result        String
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("task_decisions")
}

model Document {
  id        Int             @id @default(autoincrement())
  userId    String          @default("legacy") @map("user_id")
  filename  String
  mimeType  String          @map("mime_type")
  sizeBytes Int             @map("size_bytes")
  createdAt DateTime        @default(now()) @map("created_at")
  chunks    DocumentChunk[]

  @@index([userId])
  @@index([userId, createdAt])
  @@map("documents")
}

model DocumentChunk {
  id         Int      @id @default(autoincrement())
  documentId Int      @map("document_id")
  content    String
  chunkIndex Int      @map("chunk_index")
  embedding  Bytes
  createdAt  DateTime @default(now()) @map("created_at")
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_chunks")
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    String   @default("legacy") @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("push_subscriptions")
}

model NotificationSetting {
  id               Int      @id @default(autoincrement())
  userId           String   @default("legacy") @map("user_id")
  reminderEnabled  Boolean  @default(false) @map("reminder_enabled")
  reminderTime     String   @default("09:00") @map("reminder_time")
  budgetAlert      Boolean  @default(true) @map("budget_alert")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([userId])
  @@map("notification_settings")
}

model UserApiKey {
  id           Int      @id @default(autoincrement())
  userId       String   @map("user_id")
  provider     String
  encryptedKey String   @map("encrypted_key")
  keyHint      String   @map("key_hint")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([userId, provider])
  @@index([userId])
  @@map("user_api_keys")
}

model Subscription {
  id                 Int      @id @default(autoincrement())
  userId             String   @unique @map("user_id")
  stripeCustomerId   String?  @unique @map("stripe_customer_id")
  stripeSubscriptionId String? @unique @map("stripe_subscription_id")
  plan               String   @default("free")
  status             String   @default("active")
  currentPeriodEnd   DateTime? @map("current_period_end")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model CompassItem {
  id        Int            @id @default(autoincrement())
  userId    String         @map("user_id")
  type      String         // "text" | "url" | "image"
  title     String
  content   String
  sourceUrl String?        @map("source_url")
  imageKey  String?        @map("image_key")
  createdAt DateTime       @default(now()) @map("created_at")
  chunks    CompassChunk[]

  @@index([userId])
  @@index([userId, createdAt])
  @@map("compass_items")
}

model CompassChunk {
  id            Int         @id @default(autoincrement())
  compassItemId Int         @map("compass_item_id")
  content       String
  chunkIndex    Int         @map("chunk_index")
  embedding     Bytes
  createdAt     DateTime    @default(now()) @map("created_at")
  compassItem   CompassItem @relation(fields: [compassItemId], references: [id], onDelete: Cascade)

  @@index([compassItemId])
  @@map("compass_chunks")
}

model FeedKeyword {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  keyword   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("feed_keywords")
}

model FeedArticle {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id")
  title       String
  url         String
  source      String
  category    String
  snippet     String
  publishedAt DateTime @map("published_at")
  fetchedAt   DateTime @default(now()) @map("fetched_at")
  keyword     String
  imageUrl    String?  @map("image_url")
  isRead      Boolean  @default(false) @map("is_read")

  @@unique([userId, url])
  @@index([userId, category, publishedAt])
  @@index([userId, fetchedAt])
  @@index([fetchedAt])
  @@map("feed_articles")
}
